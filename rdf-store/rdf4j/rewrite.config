# Tomcat URL rewrite rules for the Flyover RDF4J container.
#
# RDF4J normally serves its REST API under the /rdf4j-server context, e.g.
#   http://host:7200/rdf4j-server/repositories/userRepo
# GraphDB and the QLever adapter, however, expose the same REST API at the
# server root:
#   http://host:7200/repositories/userRepo
#
# To keep the triplifier configuration identical for every backend, these
# rules transparently forward root-level REST requests to the /rdf4j-server
# context. The triplifier can therefore always use the bare base URL
# http://rdf-store:7200, with no RDF4J-specific suffix.
RewriteRule ^/repositories/(.*)$ /rdf4j-server/repositories/$1 [L]
RewriteRule ^/protocol$ /rdf4j-server/protocol [L]
