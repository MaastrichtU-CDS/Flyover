# ──────────────────────────────────────────────────────────────────────
# Default RDF store backend — committed to git so all users get GraphDB
# out of the box with plain `docker-compose up` and `docker-compose down`.
#
# To use a different backend, export the variable in your shell before
# running Compose (this takes precedence over this file):
#   export COMPOSE_PROFILES=rdf4j   # or qlever
#   docker-compose up
#
# Available backends:
#   graphdb  → Ontotext GraphDB (with reasoning)   [default]
#   rdf4j    → Eclipse RDF4J     (no reasoning)
#   qlever   → QLever            (no reasoning)
# ──────────────────────────────────────────────────────────────────────
COMPOSE_PROFILES=graphdb
